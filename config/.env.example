# Twilio SMS Configuration
# Sign up at https://www.twilio.com/try-twilio to get these credentials

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_goes_here
TWILIO_PHONE_NUMBER=+1234567890

# Instructions:
# 1. Copy this file to .env:  cp .env.example .env
# 2. Replace the values above with your actual Twilio credentials
# 3. Make sure .env is in .gitignore (it already is)
# 4. Restart the server after updating .env
#
# To send SMS to ANY number (not just verified):
# - Upgrade your Twilio account by adding a payment method
# - Visit: https://console.twilio.com/us1/billing/manage-billing/billing-overview
# - Cost: ~$0.0075 per SMS (less than 1 cent per OTP)
